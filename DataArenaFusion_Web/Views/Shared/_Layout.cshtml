<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataArenaFusion_Web</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Outfit:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DataArenaFusion_Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        #app-container { display: flex; height: 100vh; overflow: hidden; }
        #sidebar { width: 260px !important; flex-shrink: 0; display: flex; flex-direction: column; overflow-y: auto; }
        #main-content { flex-grow: 1; overflow-y: auto; background-color: var(--surface); }
        .sidebar-brand { padding: 2rem 1.5rem; text-align: left; }
        .sidebar-brand h4 { font-family: 'Outfit', sans-serif; font-size: 1.5rem; }
    </style>
</head>
<body>
    <div id="app-container">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-brand">
                <h4 class="fw-bold mb-0" style="color: var(--accent-pink);">Data Arena <span style="color: white; opacity: 0.9;">Fusion</span></h4>
                <p class="small text-muted mb-0">Analytics Engineering</p>
            </div>
            
            <div class="px-3 flex-grow-1">
                <div class="nav-group-title">IMPORTAR DATOS</div>
                <input type="file" id="fileUploader" style="display: none;" accept=".csv,.json,.xml" />
                <button class="btn w-100 text-white mb-2 text-start d-flex align-items-center" style="background: rgba(14, 165, 233, 0.15); color: #7dd3fc !important;" onclick="triggerFile('csv')">
                    <i class="bi bi-filetype-csv me-2"></i> CSV
                </button>
                <button class="btn w-100 text-white mb-2 text-start d-flex align-items-center" style="background: rgba(234, 179, 8, 0.15); color: #fde047 !important;" onclick="triggerFile('json')">
                    <i class="bi bi-filetype-json me-2"></i> JSON
                </button>
                <button class="btn w-100 text-white mb-2 text-start d-flex align-items-center" style="background: rgba(249, 115, 22, 0.15); color: #fdba74 !important;" onclick="triggerFile('xml')">
                    <i class="bi bi-filetype-xml me-2"></i> XML
                </button>
                <button class="btn w-100 text-white mb-4 text-start d-flex align-items-center" style="background: rgba(107, 114, 128, 0.15); color: #d1d5db !important;" onclick="triggerFile('txt')">
                    <i class="bi bi-file-earmark-text me-2"></i> TXT
                </button>

                <div class="nav-group-title">BASE DE DATOS</div>
                <button class="btn w-100 btn-outline-light mb-2 text-start border-0 d-flex align-items-center" style="background: rgba(255,255,255,0.05);"><i class="bi bi-database me-2"></i> MariaDB</button>
                <button class="btn w-100 btn-outline-light mb-4 text-start border-0 d-flex align-items-center" style="background: rgba(255,255,255,0.05);"><i class="bi bi-database me-2"></i> PostgreSQL</button>
                
                <div class="nav-group-title">ACCIONES RÁPIDAS</div>
                <button id="btnLimpiar" class="btn w-100 mb-2 text-start d-flex align-items-center" style="background: rgba(239, 68, 68, 0.1); color: #fca5a5 !important;">
                    <i class="bi bi-trash3 me-2"></i> Limpiar Datos
                </button>
            </div>

            <div class="mt-auto px-3 pb-4">
                <button id="btnApi" class="btn w-100 text-white fw-bold py-3 shadow-lg" style="background: linear-gradient(135deg, var(--accent-purple) 0%, #4f46e5 100%);">
                    <i class="bi bi-cloud-arrow-down me-2"></i> ENRIQUECER CON API
                </button>
            </div>
        </nav>

        <!-- Main Content -->
        <main id="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Definicion default de loadDataGrid (Index.cshtml la puede sobreescribir)
        if (typeof window.loadDataGrid !== 'function') {
            window.loadDataGrid = async function() {
                const res = await fetch('/api/DataApi/GetData');
                if (!res.ok) return;
                const result = await res.json();
                const columns = result.columns || result.Columns || [];
                const data    = result.data    || result.Data    || [];

                // Actualizar contador
                const lbl = document.getElementById('lblRegistros');
                if (lbl) lbl.innerText = data.length;

                // Encabezados
                const trHead = document.getElementById('dgvHeaders');
                const cmb    = document.getElementById('cmbFiltroColumna');
                if (trHead) {
                    trHead.innerHTML = '';
                    if (cmb) cmb.innerHTML = '<option>Todas las columnas</option>';
                    columns.forEach(col => {
                        const th = document.createElement('th');
                        th.innerText = col;
                        trHead.appendChild(th);
                        if (cmb) {
                            const opt = document.createElement('option');
                            opt.value = col;
                            opt.innerText = col;
                            cmb.appendChild(opt);
                        }
                    });
                }

                // Cuerpo de la tabla
                const tbody = document.getElementById('dgvBody');
                if (!tbody) return;
                tbody.innerHTML = '';
                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td class="text-center text-muted p-5" colspan="100%">No hay datos cargados.</td></tr>';
                    return;
                }
                const limit = Math.min(data.length, 2000);
                for (let i = 0; i < limit; i++) {
                    const row = data[i];
                    const tr = document.createElement('tr');
                    columns.forEach(col => {
                        const td = document.createElement('td');
                        // Las propiedades del json pueden venir en PascalCase o camelCase
                        const val = row[col] ?? row[col.charAt(0).toLowerCase() + col.slice(1)] ?? '';
                        if (col.endsWith('(MXN)')) td.style.textAlign = 'right';
                        td.innerText = val;
                        tr.appendChild(td);
                    });
                    tbody.appendChild(tr);
                }
            };
        }

        // Mapa de tipos a extensiones de filtro
        const fileAcceptMap = {
            'csv':  '.csv',
            'json': '.json',
            'xml':  '.xml',
            'txt':  '.txt,.csv'
        };

        function triggerFile(type) {
            const uploader = document.getElementById('fileUploader');
            // Aplicar el filtro correcto segun el boton
            uploader.accept = fileAcceptMap[type] || '*';
            // Resetear el valor para que el evento 'change' dispare aunque sea el mismo archivo
            uploader.value = '';
            uploader.click();
        }

        document.getElementById('fileUploader').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const fd = new FormData();
            fd.append('file', file);

            // Mostrar indicador de carga en la tabla
            const tbody = document.getElementById('dgvBody');
            if (tbody) {
                tbody.innerHTML = '<tr><td class="text-center p-4 text-primary" colspan="100%"><strong>⏳ Cargando datos...</strong></td></tr>';
            }
             
            try {
                console.log("1. Enviando archivo al servidor...");
                const res = await fetch('/api/DataApi/Upload', {
                    method: 'POST',
                    body: fd
                });

                if (res.ok) {
                    console.log("2. Archivo subido. Solicitando datos de vuelta...");
                    if (typeof window.loadDataGrid === 'function') {
                        await window.loadDataGrid();
                        console.log("3. ¡Tabla cargada exitosamente!");
                    } else {
                        window.location.reload();
                    }
                } else {
                    const err = await res.json().catch(() => ({ message: 'Error desconocido' }));
                    alert('Error al cargar el archivo: ' + err.message);
                    if (tbody) tbody.innerHTML = '<tr><td class="text-center text-danger p-4" colspan="100%">Error al cargar el archivo.</td></tr>';
                }
            } catch (ex) {
                // ESTE ALERT NOS DIRÁ EXACTAMENTE QUÉ PASÓ
                alert('ERROR FATAL: Revisa la consola (F12)');
                console.error("El servidor cortó la conexión abruptamente. Error detallado: ", ex);
            }
        });
    </script>
</body>
</html>
