<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataArenaFusion_Web</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Outfit:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DataArenaFusion_Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        #app-container { display: flex; height: 100vh; overflow: hidden; }
        #sidebar { width: 260px !important; flex-shrink: 0; display: flex; flex-direction: column; overflow-y: auto; }
        #main-content { flex-grow: 1; overflow-y: auto; background-color: var(--surface); }
        .sidebar-brand { padding: 2rem 1.5rem; text-align: left; }
        .sidebar-brand h4 { font-family: 'Outfit', sans-serif; font-size: 1.5rem; }
    </style>
</head>
<body>
    <div id="app-container">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-brand">
                <h4 class="fw-bold mb-0" style="color: var(--accent-pink);">Data Arena <span style="color: white; opacity: 0.9;">Fusion</span></h4>
                <p class="small text-muted mb-0">Analytics Engineering</p>
            </div>
            
            <div class="px-3 flex-grow-1">
                <div class="nav-group-title">IMPORTAR DATOS</div>
                <input type="file" id="fileUploader" style="display: none;" accept=".csv,.json,.xml" />
                <button class="btn w-100 text-white mb-2 text-start d-flex align-items-center" style="background: rgba(14, 165, 233, 0.15); color: #7dd3fc !important;" onclick="triggerFile('csv')">
                    <i class="bi bi-filetype-csv me-2"></i> CSV
                </button>
                <button class="btn w-100 text-white mb-2 text-start d-flex align-items-center" style="background: rgba(234, 179, 8, 0.15); color: #fde047 !important;" onclick="triggerFile('json')">
                    <i class="bi bi-filetype-json me-2"></i> JSON
                </button>
                <button class="btn w-100 text-white mb-2 text-start d-flex align-items-center" style="background: rgba(249, 115, 22, 0.15); color: #fdba74 !important;" onclick="triggerFile('xml')">
                    <i class="bi bi-filetype-xml me-2"></i> XML
                </button>
                <button class="btn w-100 text-white mb-4 text-start d-flex align-items-center" style="background: rgba(107, 114, 128, 0.15); color: #d1d5db !important;" onclick="triggerFile('txt')">
                    <i class="bi bi-file-earmark-text me-2"></i> TXT
                </button>

                <div class="nav-group-title">BASE DE DATOS</div>
                <button id="btnMariaDB" class="btn w-100 btn-outline-light mb-2 text-start border-0 d-flex align-items-center" style="background: rgba(255,255,255,0.05);"><i class="bi bi-database me-2"></i> MariaDB</button>
                <button id="btnPostgre" class="btn w-100 btn-outline-light mb-4 text-start border-0 d-flex align-items-center" style="background: rgba(255,255,255,0.05);"><i class="bi bi-database me-2"></i> PostgreSQL</button>
                
                <div class="nav-group-title">ACCIONES RÁPIDAS</div>
                <button id="btnLimpiar" class="btn w-100 mb-2 text-start d-flex align-items-center" style="background: rgba(239, 68, 68, 0.1); color: #fca5a5 !important;">
                    <i class="bi bi-trash3 me-2"></i> Limpiar Datos
                </button>
            </div>

            <div class="mt-auto px-3 pb-4">
                <button id="btnApi" class="btn w-100 text-white fw-bold py-3 shadow-lg" style="background: linear-gradient(135deg, var(--accent-purple) 0%, #4f46e5 100%);">
                    <i class="bi bi-cloud-arrow-down me-2"></i> ENRIQUECER CON API
                </button>
            </div>
        </nav>

        <!-- Main Content -->
        <main id="main-content">
            @RenderBody()
        </main>
    </div>

    <!-- Modal para Agrupamiento -->
    <div class="modal fade" id="modalAgrupar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
                <div class="modal-header border-0 pb-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold" id="modalAgruparTitle">Resumen de Datos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="table-responsive" style="max-height: 400px;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="sticky-top bg-white">
                                <tr style="border-bottom: 2px solid #f1f5f9;">
                                    <th class="text-uppercase small fw-bold text-muted" id="thAgruparClave">Columna</th>
                                    <th class="text-uppercase small fw-bold text-muted text-end" id="thAgruparValor">Valor / Conteo</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyAgrupar">
                                <!-- Datos cargados dinamicamente -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Modal para Conexión a Base de Datos -->
    <div class="modal fade" id="modalDbConnection" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem; background-color: white;">
                <div class="modal-header border-0 pb-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold" id="modalDbTitle" style="color: #1e293b;">Conexión a Base de Datos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-4" id="modalDbSubtitle" style="color: #64748b; font-weight: 500;">Configura los parámetros de acceso</p>
                    
                    <input type="hidden" id="dbProvider" />

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label small fw-bold text-muted">SERVIDOR / IP</label>
                            <input type="text" id="dbHost" class="form-control border-0 shadow-sm" placeholder="localhost" style="background-color: #f8fafc; height: 45px;">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">PUERTO</label>
                            <input type="number" id="dbPort" class="form-control border-0 shadow-sm" style="background-color: #f8fafc; height: 45px;">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">BASE DE DATOS</label>
                            <input type="text" id="dbName" class="form-control border-0 shadow-sm" style="background-color: #f8fafc; height: 45px;">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">USUARIO</label>
                            <input type="text" id="dbUser" class="form-control border-0 shadow-sm" style="background-color: #f8fafc; height: 45px;">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">CONTRASEÑA</label>
                            <input type="password" id="dbPass" class="form-control border-0 shadow-sm" style="background-color: #f8fafc; height: 45px;">
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dbSsl">
                                <label class="form-check-label small fw-bold text-muted" for="dbSsl">
                                    USAR SSL / TLS
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="dbConnStatus" class="mt-3 small fw-bold text-center" style="display:none; padding: 10px; border-radius: 8px;"></div>
                </div>
                <div class="modal-footer border-0 p-4 pt-2 d-flex gap-2">
                    <button type="button" class="btn px-4 fw-bold" id="btnTestConn" style="background-color: #f1f5f9; color: #475569;">PROBAR</button>
                    <div class="ms-auto">
                        <button type="button" class="btn px-4 fw-bold text-muted border-0 bg-transparent" data-bs-dismiss="modal">CANCELAR</button>
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" id="btnAcceptConn" style="background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); border:0;">ACEPTAR</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
