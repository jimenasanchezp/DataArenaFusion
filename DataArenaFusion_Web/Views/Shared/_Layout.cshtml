<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataArenaFusion_Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DataArenaFusion_Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { margin: 0; padding: 0; height: 100vh; overflow: hidden; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f1f4f9; }
        #app-container { display: flex; height: 100vh; }
        #sidebar { width: 240px; background-color: #111827; color: white; display: flex; flex-direction: column; }
        #main-content { flex-grow: 1; overflow-y: auto; padding: 0; }
    </style>
</head>
<body>
    <div id="app-container">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="px-3 py-2 text-center" style="margin-top: 5px; margin-bottom: 20px;">
                <h4 style="color: #ff2e73; font-weight: bold; margin:0;">Data Arena <br/><span style="color:white; font-size: 0.9em;">Fusion</span></h4>
            </div>
            
            <div class="px-3">
                <h6 class="text-uppercase text-secondary small fw-bold mb-3">Importar Datos</h6>
                
                <input type="file" id="fileUploader" style="display: none;" accept=".csv,.json,.xml" />
                <button class="btn w-100 text-white mb-2 fw-bold text-start" style="background-color: #0ea5e9; border:none;" onclick="triggerFile('csv')">CSV</button>
                <button class="btn w-100 text-dark mb-2 fw-bold text-start" style="background-color: #eab308; border:none;" onclick="triggerFile('json')">JSON</button>
                <button class="btn w-100 text-white mb-2 fw-bold text-start" style="background-color: #f97316; border:none;" onclick="triggerFile('xml')">XML</button>
                <button class="btn w-100 text-white mb-4 fw-bold text-start" style="background-color: #6b7280; border:none;" onclick="triggerFile('txt')">TXT</button>

                <h6 class="text-uppercase text-secondary small fw-bold mb-3">Base de Datos</h6>
                <button class="btn w-100 btn-outline-light mb-2 text-start"><i class="bi bi-database"></i> MariaDB</button>
                <button class="btn w-100 btn-outline-light mb-4 text-start"><i class="bi bi-database"></i> PostgreSQL</button>
                
                <h6 class="text-uppercase text-secondary small fw-bold mb-3">Acciones Rápidas</h6>
                <button id="btnLimpiar" class="btn w-100 btn-outline-danger mb-2 text-start fw-bold">Limpiar Datos</button>
            </div>

            <div class="mt-auto px-3 pb-4">
                <button id="btnConsola" class="btn w-100 text-white fw-bold mb-2 text-center py-2" style="background-color: #ff2e73; border:none;">Abrir Consola</button>
                <button id="btnApi" class="btn w-100 text-white fw-bold text-center py-2" style="background-color: #4b2eff; border:none;">API</button>
            </div>
        </nav>

        <!-- Main Content -->
        <main id="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Definicion default de loadDataGrid (Index.cshtml la puede sobreescribir)
        window.loadDataGrid = async function() {
            const res = await fetch('/api/DataApi/GetData');
            if (!res.ok) return;
            const result = await res.json();
            const columns = result.columns || result.Columns || [];
            const data    = result.data    || result.Data    || [];

            // Actualizar contador
            const lbl = document.getElementById('lblRegistros');
            if (lbl) lbl.innerText = data.length;

            // Encabezados
            const trHead = document.getElementById('dgvHeaders');
            const cmb    = document.getElementById('cmbFiltroColumna');
            if (trHead) {
                trHead.innerHTML = '';
                if (cmb) cmb.innerHTML = '<option>Todas las columnas</option>';
                columns.forEach(col => {
                    const th = document.createElement('th');
                    th.innerText = col;
                    trHead.appendChild(th);
                    if (cmb) {
                        const opt = document.createElement('option');
                        opt.value = col;
                        opt.innerText = col;
                        cmb.appendChild(opt);
                    }
                });
            }

            // Cuerpo de la tabla
            const tbody = document.getElementById('dgvBody');
            if (!tbody) return;
            tbody.innerHTML = '';
            if (data.length === 0) {
                tbody.innerHTML = '<tr><td class="text-center text-muted p-5" colspan="100%">No hay datos cargados.</td></tr>';
                return;
            }
            const limit = Math.min(data.length, 2000);
            for (let i = 0; i < limit; i++) {
                const row = data[i];
                const tr = document.createElement('tr');
                columns.forEach(col => {
                    const td = document.createElement('td');
                    // Las propiedades del json pueden venir en PascalCase o camelCase
                    const val = row[col] ?? row[col.charAt(0).toLowerCase() + col.slice(1)] ?? '';
                    if (col.endsWith('(MXN)')) td.style.textAlign = 'right';
                    td.innerText = val;
                    tr.appendChild(td);
                });
                tbody.appendChild(tr);
            }
        };

        // Mapa de tipos a extensiones de filtro
        const fileAcceptMap = {
            'csv':  '.csv',
            'json': '.json',
            'xml':  '.xml',
            'txt':  '.txt,.csv'
        };

        function triggerFile(type) {
            const uploader = document.getElementById('fileUploader');
            // Aplicar el filtro correcto segun el boton
            uploader.accept = fileAcceptMap[type] || '*';
            // Resetear el valor para que el evento 'change' dispare aunque sea el mismo archivo
            uploader.value = '';
            uploader.click();
        }

        document.getElementById('fileUploader').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const fd = new FormData();
            fd.append('file', file);

            // Mostrar indicador de carga en la tabla
            const tbody = document.getElementById('dgvBody');
            if (tbody) {
                tbody.innerHTML = '<tr><td class="text-center p-4 text-primary" colspan="100%"><strong>⏳ Cargando datos...</strong></td></tr>';
            }

            try {
                const res = await fetch('/api/DataApi/Upload', {
                    method: 'POST',
                    body: fd
                });

                if (res.ok) {
                    // Esperar a que loadDataGrid este disponible (se define en Index.cshtml)
                    if (typeof window.loadDataGrid === 'function') {
                        await window.loadDataGrid();
                    } else {
                        // Fallback: recargar la pagina
                        window.location.reload();
                    }
                } else {
                    const err = await res.json().catch(() => ({ message: 'Error desconocido' }));
                    alert('Error al cargar el archivo: ' + (err.message || res.statusText));
                    if (tbody) tbody.innerHTML = '<tr><td class="text-center text-danger p-4" colspan="100%">Error al cargar el archivo.</td></tr>';
                }
            } catch (ex) {
                alert('Error de red: ' + ex.message);
            }
        });
    </script>
</body>
</html>
