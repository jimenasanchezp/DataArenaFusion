@{
    ViewData["Title"] = "Data Arena Fusion";
}

<div class="h-100 d-flex flex-column" style="background-color: var(--surface);">
    <ul class="nav nav-tabs bg-white pt-3 px-4" id="mainTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tabla-tab" data-bs-toggle="tab" data-bs-target="#tabla-pane" type="button" role="tab">
                <i class="bi bi-grid-3x3 me-2"></i>Tabla de Datos
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="grafica-tab" data-bs-toggle="tab" data-bs-target="#grafica-pane" type="button" role="tab">
                <i class="bi bi-graph-up-arrow me-2"></i>Análisis Visual
            </button>
        </li>
    </ul>

    <div class="tab-content flex-grow-1 d-flex flex-column" id="mainTabsContent" style="overflow: hidden;">
        <div class="tab-pane fade show active h-100" id="tabla-pane" role="tabpanel">
            <div class="d-flex flex-column h-100">
                <div class="filter-panel px-4 py-3 d-flex align-items-center flex-wrap gap-4">
                    <div class="d-flex align-items-center">
                        <span class="text-uppercase small fw-bold text-muted me-2">Registros</span>
                        <span class="badge rounded-pill px-3 py-2" style="background-color: rgba(15, 23, 42, 0.05); color: var(--primary); font-size: 0.9rem;" id="lblRegistros">0</span>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted">FILTRAR POR:</label>
                        <select id="cmbFiltroColumna" class="form-select border-0 shadow-sm" style="width: 220px; height: 42px; background-color: white;">
                            <option>Todas las columnas</option>
                        </select>
                    </div>

                    <div class="ms-auto d-flex gap-2">
                        <button id="btnOrdenar" class="btn text-white px-4" style="background-color: var(--accent-blue);"><i class="bi bi-sort-alpha-down me-2"></i>Ordenar</button>
                        <button id="btnAgrupar" class="btn text-white px-4" style="background-color: var(--accent-purple);"><i class="bi bi-collection me-2"></i>Agrupar</button>
                        <button id="btnDuplicados" class="btn text-white px-4" style="background-color: #f43f5e;"><i class="bi bi-files me-2"></i>Duplicados</button>
                    </div>
                </div>

                <div class="flex-grow-1 p-4" style="overflow: auto;">
                    <div class="dgv-table shadow-sm">
                        <table class="table table-hover mb-0" id="dgvDatos">
                            <thead><tr id="dgvHeaders"></tr></thead>
                            <tbody id="dgvBody">
                                <tr><td class="text-center text-muted p-5" colspan="100%">No hay datos cargados. Importa un archivo desde el panel lateral.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mt-3 px-2">
                        <div class="text-muted small" id="tblPageInfo">Sin datos</div>
                        <div class="d-flex align-items-center gap-2">
                            <select id="cmbPageSize" class="form-select form-select-sm border-0 shadow-sm" style="width: 120px; background: white;">
                                <option value="50">50</option>
                                <option value="100" selected>100</option>
                                <option value="200">200</option>
                                <option value="500">500</option>
                                <option value="1000">1000</option>
                                <option value="5000">5000</option>
                            </select>
                            <button class="btn btn-sm btn-outline-secondary" id="btnPrevPage" disabled>Anterior</button>
                            <button class="btn btn-sm btn-outline-secondary" id="btnNextPage" disabled>Siguiente</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade h-100" id="grafica-pane" role="tabpanel" style="background-color: #f8fafc;">
            <div class="d-flex flex-column h-100">
                <div class="px-4 py-3 border-bottom bg-white d-flex align-items-center gap-4 shadow-sm">
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-uppercase" style="letter-spacing: 0.5px;">Eje X:</label>
                        <select id="cmbEjeX" class="form-select form-select-sm border-0 shadow-none bg-light" style="width:180px; font-weight: 500;" onchange="generarGrafica()"></select>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-uppercase" style="letter-spacing: 0.5px;">Eje Y (#):</label>
                        <select id="cmbEjeY" class="form-select form-select-sm border-0 shadow-none bg-light" style="width:180px; font-weight: 500;" onchange="generarGrafica()"></select>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-uppercase" style="letter-spacing: 0.5px;">Tipo:</label>
                        <select id="cmbTipoGrafica" class="form-select form-select-sm border-0 shadow-none bg-light" style="width:140px; font-weight: 500;" onchange="generarGrafica()">
                            <option value="bar">Barras</option>
                            <option value="pie">Pastel</option>
                            <option value="line">Línea</option>
                            <option value="doughnut">Dona</option>
                        </select>
                    </div>
                    <div class="ms-auto">
                        <button class="btn btn-sm btn-outline-primary fw-bold px-3" onclick="generarGrafica()"><i class="bi bi-arrow-clockwise me-1"></i>Actualizar</button>
                    </div>
                </div>

                <div class="flex-grow-1 p-4 d-flex align-items-center justify-content-center">
                    <div class="bg-white p-4 rounded-4 shadow-lg w-100 h-100 d-flex flex-column align-items-center justify-content-center" style="position: relative;">
                        <canvas id="chartPrincipal" style="display: none; width: 100% !important; height: 100% !important;"></canvas>
                        <div id="chartPlaceholder" class="text-center p-5">
                            <div class="bi bi-bar-chart-steps mb-3" style="font-size: 4rem; color: var(--accent-blue); opacity: 0.15;"></div>
                            <h5 class="text-muted fw-bold mb-2">Visualizador de Datos</h5>
                            <p class="text-muted small">Selecciona los ejes para generar una representación visual de los datos cargados.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>
}
