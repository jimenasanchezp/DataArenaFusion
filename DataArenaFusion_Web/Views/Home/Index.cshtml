@{
    ViewData["Title"] = "Data Arena Fusion";
}



<div class="h-100 d-flex flex-column" style="background-color: var(--surface);">
    <ul class="nav nav-tabs bg-white pt-3 px-4" id="mainTabs" role="tablist">

        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tabla-tab" data-bs-toggle="tab" data-bs-target="#tabla-pane" type="button" role="tab"><i class="bi bi-grid-3x3 me-2"></i>Tabla de Datos</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="grafica-tab" data-bs-toggle="tab" data-bs-target="#grafica-pane" type="button" role="tab"><i class="bi bi-graph-up-arrow me-2"></i>Análisis Visual</button>
        </li>
    </ul>

    <div class="tab-content flex-grow-1 d-flex flex-column" id="mainTabsContent" style="overflow: hidden;">
        
        <div class="tab-pane fade show active h-100 flex-column" id="tabla-pane" role="tabpanel" style="display: flex;">
            <div class="filter-panel px-4 py-3 d-flex align-items-center flex-wrap gap-4">
                <div class="d-flex align-items-center">
                    <span class="text-uppercase small fw-bold text-muted me-2">Registros</span>
                    <span class="badge rounded-pill px-3 py-2" style="background-color: rgba(15, 23, 42, 0.05); color: var(--primary); font-size: 0.9rem;" id="lblRegistros">0</span>
                </div>
                
                <div class="d-flex align-items-center gap-2">
                    <label class="small fw-bold text-muted">FILTRAR POR:</label>
                    <select id="cmbFiltroColumna" class="form-select border-0 shadow-sm" style="width: 220px; height: 42px; background-color: white;">
                        <option>Todas las columnas</option>
                    </select>
                </div>

                <div class="ms-auto d-flex gap-2">
                    <button class="btn text-white px-4" style="background-color: var(--accent-blue);" onclick="accionAPI('Ordenar')"><i class="bi bi-sort-alpha-down me-2"></i>Ordenar</button>
                    <button class="btn text-white px-4" style="background-color: var(--accent-purple);" onclick="accionAPI('Agrupar')"><i class="bi bi-collection me-2"></i>Agrupar</button>
                    <button class="btn text-white px-4" style="background-color: #f43f5e;" onclick="accionAPI('Duplicados')"><i class="bi bi-files me-2"></i>Duplicados</button>
                </div>
            </div>

            <div class="flex-grow-1 p-4" style="overflow: auto;">
                <div class="dgv-table shadow-sm">
                    <table class="table table-hover mb-0" id="dgvDatos">
                        <thead><tr id="dgvHeaders"></tr></thead>
                        <tbody id="dgvBody">
                            <tr><td class="text-center text-muted p-5" colspan="100%">No hay datos cargados. Importa un archivo desde el panel lateral.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade h-100 flex-column" id="grafica-pane" role="tabpanel" style="display:flex; flex-direction:column; background-color: var(--surface);">
            <div class="filter-panel px-4 py-3 d-flex align-items-center flex-wrap gap-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted">EJE X:</label>
                        <select id="cmbEjeX" class="form-select border-0 shadow-sm" style="width:180px; height: 42px;" onchange="generarGrafica()"></select>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted">EJE Y (#):</label>
                        <select id="cmbEjeY" class="form-select border-0 shadow-sm" style="width:180px; height: 42px;" onchange="generarGrafica()"></select>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted">ESTILO:</label>
                        <select id="cmbTipoGrafica" class="form-select border-0 shadow-sm" style="width:140px; height: 42px;" onchange="generarGrafica()">
                            <option value="bar">Barras</option>
                            <option value="pie">Pastel</option>
                            <option value="line">Línea</option>
                            <option value="doughnut">Dona</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-center p-4">
                <div class="bg-white p-4 rounded-4 shadow-sm w-100 h-100 d-flex align-items-center justify-content-center" style="max-width: 1100px;">
                    <canvas id="chartPrincipal" style="display: none;"></canvas>
                    <div id="chartPlaceholder" class="text-center">
                         <div class="bi bi-bar-chart-steps mb-3" style="font-size: 3rem; color: var(--text-muted); opacity: 0.3;"></div>
                         <p class="text-muted fw-semibold">Selecciona una columna o importa datos para generar una gráfica interactiva.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    let _globalColumns = [];
    let _globalData    = [];
    let _chartInstance = null;

    window.loadDataGrid = async function() {
        const res = await fetch('/api/DataApi/GetData');
        if (!res.ok) return;
        const result = await res.json();
        _globalColumns = result.columns || [];
        _globalData    = result.data    || [];

        renderTable(_globalColumns, _globalData);
        poblarSelectorGrafica(_globalColumns, _globalData);
        
        // AUTO-GENERAR GRÁFICA AL CARGAR ARCHIVO (Igual que en WinForms)
        if (_globalData.length > 0) {
            generarGrafica();
        }
    };

    function renderTable(columns, data) {
        document.getElementById('lblRegistros').innerText = data.length;
        const trHead = document.getElementById('dgvHeaders');
        trHead.innerHTML = '';
        const cmb = document.getElementById('cmbFiltroColumna');
        cmb.innerHTML = '<option>Todas las columnas</option>';

        columns.forEach(col => {
            const th = document.createElement('th');
            th.innerText = col;
            trHead.appendChild(th);
            const opt = document.createElement('option');
            opt.value = col; opt.innerText = col;
            cmb.appendChild(opt);
        });

        const tbody = document.getElementById('dgvBody');
        tbody.innerHTML = '';
        if (data.length === 0) {
            tbody.innerHTML = '<tr><td class="text-center p-5 text-muted" colspan="100%">No hay datos cargados.</td></tr>';
            return;
        }
        const limit = Math.min(data.length, 2000);
        for (let i = 0; i < limit; i++) {
            const row = data[i];
            const tr = document.createElement('tr');
            columns.forEach(col => {
                const td = document.createElement('td');
                const val = row[col] ?? '';
                if (col.endsWith('(MXN)')) td.style.textAlign = 'right';
                td.innerText = val;
                tr.appendChild(td);
            });
            tbody.appendChild(tr);
        }
    }

    function poblarSelectorGrafica(columns, data) {
        const cmbX = document.getElementById('cmbEjeX');
        const cmbY = document.getElementById('cmbEjeY');
        if (!cmbX || !cmbY) return;

        cmbX.innerHTML = '';
        cmbY.innerHTML = '';

        const numericas = columns.filter(col => {
            const val = data.find(r => r[col] !== '' && r[col] !== null)?.[col];
            return val !== undefined && !isNaN(parseFloat(String(val).replace(/[^0-9.-]/g, '')));
        });
        const texto = columns.filter(c => !numericas.includes(c));

        [...texto, ...numericas].forEach(col => {
            const o = document.createElement('option');
            o.value = col; o.innerText = col;
            cmbX.appendChild(o);
        });

        [...numericas, ...texto].forEach(col => {
            const o = document.createElement('option');
            o.value = col; o.innerText = col;
            cmbY.appendChild(o);
        });
    }

    function generarGrafica() {
        const ejeX  = document.getElementById('cmbEjeX')?.value;
        const ejeY  = document.getElementById('cmbEjeY')?.value;
        const tipo  = document.getElementById('cmbTipoGrafica')?.value || 'bar';
        const placeholder = document.getElementById('chartPlaceholder');

        if (!_globalData.length || !ejeX || !ejeY) return;

        // LÓGICA DE WINFORMS RECREADA: 
        // Determina si sumar (si es numérico) o contar (si es texto)
        const isNumericY = _globalData.some(row => {
            const val = row[ejeY];
            return val !== undefined && val !== '' && val !== null && !isNaN(parseFloat(String(val).replace(/[^0-9.-]/g, '')));
        });

        const grupos = {};
        _globalData.forEach(row => {
            const labelKey = row[ejeX] ?? '(vacío)';
            
            if (isNumericY) {
                // Es un número: SUMAMOS
                const raw = String(row[ejeY] ?? '0').replace(/[^0-9.-]/g, '');
                const num = parseFloat(raw) || 0;
                grupos[labelKey] = (grupos[labelKey] || 0) + num;
            } else {
                // Es texto: CONTAMOS frecuencias
                grupos[labelKey] = (grupos[labelKey] || 0) + 1;
            }
        });

        // Ordenar de mayor a menor y tomar el TOP 20 como en WinForms
        const entries = Object.entries(grupos)
                              .sort((a, b) => b[1] - a[1])
                              .slice(0, 20);

        const labels  = entries.map(e => e[0]);
        const values  = entries.map(e => parseFloat(e[1].toFixed(2)));
        const palette = labels.map((_, i) => `hsl(${(i * 37) % 360}, 70%, 55%)`);

        if (_chartInstance) { _chartInstance.destroy(); _chartInstance = null; }
        const canvas = document.getElementById('chartPrincipal');
        if (placeholder) placeholder.style.display = 'none';
        canvas.style.display = 'block';

        _chartInstance = new Chart(canvas, {
            type: tipo,
            data: {
                labels,
                datasets: [{
                    label: isNumericY ? `Suma de ${ejeY} por ${ejeX}` : `Conteo de ${ejeY} por ${ejeX}`,
                    data: values,
                    backgroundColor: palette,
                    borderColor: palette.map(c => c.replace('55%', '40%')),
                    borderWidth: tipo === 'bar' || tipo === 'line' ? 1.5 : 2,
                    tension: 0.4 
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: tipo === 'pie' || tipo === 'doughnut' },
                    title: {
                        display: true,
                        text: `${tipo.charAt(0).toUpperCase()+tipo.slice(1)}: ${ejeX} vs ${ejeY}`,
                        font: { size: 15, weight: 'bold' },
                        color: '#111827'
                    }
                },
                scales: (tipo === 'bar' || tipo === 'line') ? {
                    x: { ticks: { maxRotation: 35, font: { size: 11 } } },
                    y: { beginAtZero: true }
                } : {}
            }
        });
    }

    async function accionAPI(accion) {
        const dgvBody = document.getElementById('dgvBody');
        dgvBody.style.opacity = '0.5';

        try {
            if (accion === 'Ordenar') {
                await fetch('/api/DataApi/Ordenar', { method: 'POST' });
            } else if (accion === 'Agrupar') {
                alert("La función de agrupar en tabla aún no está conectada al servidor.");
            } else if (accion === 'Duplicados') {
                const col = document.getElementById('cmbFiltroColumna').value;
                if (col === 'Todas las columnas') {
                    alert('Selecciona una columna específica para buscar duplicados.');
                    return; 
                }
                const res = await fetch('/api/DataApi/Duplicados?columna=' + encodeURIComponent(col), { method: 'POST' });
                if (res.ok) {
                    const duplicados = await res.json();
                    const rows = document.querySelectorAll('#dgvBody tr');
                    const colIdx = _globalColumns.indexOf(col);
                    rows.forEach(tr => {
                        const cellVal = tr.cells[colIdx]?.innerText ?? '';
                        tr.style.backgroundColor = duplicados.includes(cellVal) ? '#fee2e2' : '';
                    });
                    alert(`Se encontraron ${duplicados.length} valores duplicados en "${col}". Están resaltados en rojo.`);
                    return; 
                }
            }
            await window.loadDataGrid();
        } catch (error) {
            alert("Ocurrió un error de red: " + error.message);
        } finally {
            dgvBody.style.opacity = '1';
        }
    }

    const btnApi = document.getElementById('btnApi');
    if (btnApi) {
        btnApi.addEventListener('click', async () => {
            btnApi.innerText = "Procesando...";
            btnApi.disabled = true;
            try {
                await fetch('/api/DataApi/EnriquecerApi', { method: 'POST' });
                await window.loadDataGrid();
                alert("Datos enriquecidos con éxito desde las APIs de internet.");
            } catch(e) {
                alert("Error de red: " + e.message);
            } finally {
                btnApi.innerText = "API";
                btnApi.disabled = false;
            }
        });
    }

    const btnLimpiar = document.getElementById('btnLimpiar');
    if (btnLimpiar) {
        btnLimpiar.addEventListener('click', async () => {
            await fetch('/api/DataApi/Limpiar', { method: 'POST' });
            _globalColumns = []; _globalData = [];
            document.getElementById('dgvHeaders').innerHTML = '';
            document.getElementById('dgvBody').innerHTML = '<tr><td class="text-center p-5 text-muted" colspan="100%">No hay datos cargados.</td></tr>';
            document.getElementById('lblRegistros').innerText = "0";
            if (_chartInstance) { _chartInstance.destroy(); _chartInstance = null; }
            const ph = document.getElementById('chartPlaceholder');
            if (ph) ph.style.display = '';
            const cv = document.getElementById('chartPrincipal');
            if (cv) cv.style.display = 'none';
        });
    }

    window.loadDataGrid();
</script>
}